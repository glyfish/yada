# Copy to .env and fill in. The real .env is gitignored.
# Data-source keys (FRED/BLS/Tiingo) are shared with the navi library.

# --- LLM provider ---------------------------------------------------------
# Provide the key matching LLM_MODEL_PROVIDER (default: openai).
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
LLM_MODEL_PROVIDER=openai
AGENT_LLM_MODEL=gpt-4.1
# FILTER_LLM_MODEL=gpt-4.1-mini
# SCORING_LLM_MODEL=gpt-4.1-mini

# --- Data sources ---------------------------------------------------------
# FRED  — https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your_fred_api_key_here
# BLS   — https://data.bls.gov/registrationEngine/
BLS_API_KEY=your_bls_api_key_here
# Tiingo — https://www.tiingo.com/account/api/token
TINGO_API_KEY=your_tiingo_api_key_here

# --- Web search -----------------------------------------------------------
# Tavily — https://tavily.com/
TAVILY_API_KEY=your_tavily_api_key_here

# --- GitHub (optional, for loading repos into the code RAG store) ---------
# GITHUB_API_KEY=your_github_token_here

# --- Database -------------------------------------------------------------
YADA_DB_URL=postgresql+psycopg2://user:password@localhost:5432/yada

# --- MCP data server (optional; default shown) ----------------------------
# MCP_URL=http://localhost:8080/sse

# --- Retrieval / runtime (optional) ---------------------------------------
# RAG_SCORE_THRESHOLD=0.3
# YADA_CHECKPOINT_DIR=.langgraph

# --- LangSmith tracing (optional) -----------------------------------------
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=your_langsmith_api_key_here
# LANGCHAIN_PROJECT=yada
